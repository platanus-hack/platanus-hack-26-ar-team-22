# =============================================================
# Tranquera interceptor — environment variables
# Copy to .env and fill in.
# =============================================================

# Postgres shared with web/ (see root docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://team22:team22@localhost:5432/team22

# Upstream Anthropic API.
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com

# API key dedicada al NL judge (Layer 3, Haiku 4.5). Si está vacía, NL queda
# deshabilitado y el proxy se comporta como v0.1 (regex + passthrough).
# Sacala de https://console.anthropic.com/settings/keys
ANTHROPIC_JUDGE_API_KEY=

# Single-tenant org for the hack (matches web/.env.local DEMO_ORG_ID).
DEFAULT_ORG_ID=demo

# Server bind.
HOST=0.0.0.0
PORT=8080
